{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "kairos",
  "displayName": "Kairos Astrology",
  "version": "1.1.0",
  "description": "Astrology-based decision support using Swiss Ephemeris. Computes accurate charts (horary, transit, natal, electional) with classical dignities and returns calibrated verdicts.",
  "author": {
    "name": "Dustin Lee",
    "url": "https://github.com/stardustxx"
  },
  "homepage": "https://github.com/stardustxx/kairos",
  "repository": "https://github.com/stardustxx/kairos",
  "license": "AGPL-3.0-or-later",
  "keywords": ["astrology", "swiss-ephemeris", "horary", "electional", "decision-support"],
  "mcpServers": {
    "kairos": {
      "command": "npx",
      "args": ["-y", "kairos-astrology", "mcp"]
    }
  }
}
